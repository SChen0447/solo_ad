    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/node": "^20.4.0",
    "@types/react": "^18.2.14",
    "@types/react-dom": "^18.2.6",
    "@types/react-window": "^1.8.5",
    "@types/uuid": "^9.0.2",
    "@vitejs/plugin-react": "^4.0.1",
    "concurrently": "^8.2.0",
    "ts-node": "^10.9.1",
