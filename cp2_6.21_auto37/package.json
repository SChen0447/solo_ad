{
  "name": "skill-workshop-platform",
  "version": "1.0.0",
  "description": "技能工作坊管理平台 - 课程管理、作业提交与批改、实时通知",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/server.ts",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router-dom": "6.21.0",
    "express": "4.18.2",
    "cors": "2.8.5"
  },
  "devDependencies": {
    "typescript": "5.3.3",
    "vite": "5.0.8",
    "@vitejs/plugin-react": "4.2.0",
    "@types/react": "18.2.43",
    "@types/react-dom": "18.2.17",
    "@types/express": "4.17.21",
    "@types/cors": "2.8.17",
    "@types/node": "20.10.5",
    "tsx": "4.7.0",
    "concurrently": "8.2.2"
  }
}
