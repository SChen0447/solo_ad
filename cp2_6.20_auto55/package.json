  },
  "devDependencies": {
    "@vitejs/plugin-react": "4.2.0",
    "@types/react": "18.2.42",
    "@types/react-dom": "18.2.17",
    "@types/express": "4.17.21",
    "@types/node": "20.10.5",
    "typescript": "5.3.3",
    "vite": "5.0.8",
    "tsx": "4.7.0",
    "concurrently": "8.2.2"
  }
