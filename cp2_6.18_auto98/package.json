{
  "name": "anonymous-voting-board",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:server\" \"npm:client\"",
    "server": "tsc -p tsconfig.server.json && node dist/index.js",
    "client": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.13",
    "@types/uuid": "^9.0.2",
    "@types/node": "^20.4.5",
    "typescript": "^5.1.6",
    "vite": "^4.4.5",
    "@vitejs/plugin-react": "^4.0.3",
    "ts-node": "^10.9.1",
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.1"
  }
}
