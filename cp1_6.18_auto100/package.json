{
  "name": "collab-score-editor",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:server": "tsx src/server/server.ts",
    "dev:client": "vite",
    "dev": "concurrently -k -n server,client -c cyan,magenta \"tsx src/server/server.ts\" \"vite\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "uuid": "^10.0.0",
    "vite": "^5.3.4",
    "ws": "^8.18.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.11",
    "concurrently": "^8.2.2",
    "tsx": "^4.16.2"
  }
}
