          "importance": "large",
          "position": [0, 0, 0],
          "connections": ["h2", "h3", "h4", "h5"]
        },
        {
          "id": "h2",
          "title": "古埃及文明",
          "summary": "尼罗河流域的古老文明，以金字塔、象形文字和木乃伊闻名，延续三千年之久。",
          "importance": "medium",
          "position": [3, 2, 1],
          "connections": ["h1", "h6"]
        },
        {
          "id": "h3",
          "title": "两河流域文明",
          "summary": "幼发拉底河与底格里斯河流域，苏美尔人创造楔形文字，古巴比伦颁布汉谟拉比法典。",
          "importance": "medium",
          "position": [-3, 2, 2],
          "connections": ["h1", "h7"]
        },
