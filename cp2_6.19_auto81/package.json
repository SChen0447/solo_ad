{
  "name": "resume-analyzer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "client:dev": "vite",
    "server:dev": "nodemon --watch src/server --exec \"npx tsx src/server/main.ts\"",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "build": "tsc -b && vite build",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "express": "4.18.2",
    "cors": "2.8.5",
    "multer": "1.4.5-lts.1",
    "lucide-react": "^0.511.0"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/cors": "2.8.17",
    "@types/multer": "1.4.12",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.2.0",
    "typescript": "5.3.3",
    "vite": "5.0.8",
    "concurrently": "9.2.0",
    "nodemon": "3.1.10",
    "tsx": "4.20.3",
    "vite-tsconfig-paths": "5.1.4"
  }
}
