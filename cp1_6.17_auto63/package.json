{
  "name": "galaxy-sandbox",
  "version": "1.0.0",
  "description": "2D银河系沙盒演化模拟器 - 基于重力模拟的N体互动系统",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "vite",
