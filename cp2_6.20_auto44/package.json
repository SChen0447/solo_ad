{
  "name": "ai-style-transfer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "client:dev": "vite",
    "server:dev": "nodemon --watch server --exec \"tsx server/index.ts\"",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "build": "tsc -b && vite build",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "express": "4.18.2",
    "multer": "1.4.5-lts.1",
    "sharp": "0.33.2",
    "canvas-confetti": "1.9.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "@types/express": "4.17.21",
    "@types/multer": "1.4.11",
    "@types/canvas-confetti": "1.6.4",
    "@types/cors": "2.8.17",
    "@types/node": "20.11.0",
    "@vitejs/plugin-react": "4.2.0",
    "typescript": "5.3.3",
    "vite": "5.0.8",
    "concurrently": "8.2.2",
    "nodemon": "3.0.3",
    "tsx": "4.7.0"
  }
}
