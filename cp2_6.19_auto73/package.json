{
  "name": "collaborative-whiteboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "client:dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "server:dev": "nodemon",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\""
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "cors": "2.8.5",
    "lucide-react": "^0.511.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "uuid": "9.0.0",
    "ws": "8.16.0",
    "zustand": "^5.0.3",
    "express": "4.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "4.17.21",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^9.0.8",
    "@types/ws": "8.5.10",
    "@vitejs/plugin-react": "4.2.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "nodemon": "^3.1.10",
    "tsx": "^4.20.3",
    "typescript": "5.3.3",
    "vite": "5.0.8",
    "vite-tsconfig-paths": "^5.1.4"
