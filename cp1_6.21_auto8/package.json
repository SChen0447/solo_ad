{
  "name": "flowforge-workflow-automation",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "ts-node --esm src/backend/server.ts",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reactflow": "^11.10.4",
    "socket.io-client": "^4.7.5",
    "zustand": "^4.5.2",
    "lucide-react": "^0.378.0",
    "express": "^4.19.2",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.1",
    "cron-parser": "^4.9.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@types/express": "^4.17.21",
    "@types/uuid": "^9.0.8",
    "@types/cors": "^2.8.17",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.10",
    "ts-node": "^10.9.2",
    "concurrently": "^8.2.2",
    "tailwindcss": "^3.4.3",
    "postcss": "^8.4.38",
    "autoprefixer": "^10.4.19"
  }
