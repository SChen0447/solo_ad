{
  "name": "visual-notes-graph",
  "version": "1.0.0",
  "description": "Visual knowledge graph notes application",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "npx tsx src/server/server.ts",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "2.8.5",
    "express": "4.18.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "uuid": "9.0.0"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "@types/uuid": "9.0.7",
    "@vitejs/plugin-react": "4.2.0",
    "concurrently": "8.2.2",
    "ts-node": "10.9.2",
    "tslib": "2.6.2",
    "tsx": "^4.22.4",
    "typescript": "5.3.3",
    "vite": "5.0.8"
  }
}
