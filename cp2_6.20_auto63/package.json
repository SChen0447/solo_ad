{
  "name": "volunteer-management-system",
  "version": "1.0.0",
  "description": "Community volunteer team management system",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "ts-node --project tsconfig.server.json src/server/index.ts",
    "client": "vite",
    "build": "tsc && vite build"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router-dom": "6.20.0",
    "express": "4.18.2"
  },
  "devDependencies": {
    "typescript": "5.3.3",
    "vite": "5.0.8",
    "@vitejs/plugin-react": "4.2.0",
    "@types/react": "18.2.42",
    "@types/react-dom": "18.2.17",
    "@types/express": "4.17.21",
    "@types/node": "20.10.4",
    "ts-node": "10.9.2",
    "concurrently": "8.2.2"
  }
}
