{
  "name": "collaborative-whiteboard",
  "version": "1.0.0",
  "description": "在线协同白板与团队头脑风暴应用",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node --loader ts-node/esm server/index.ts",
    "client": "vite",
    "build": "tsc && vite build"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.1",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.0",
    "socket.io": "^4.6.1",
    "socket.io-client": "^4.6.1"
  },
  "devDependencies": {
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.13",
    "@types/uuid": "^9.0.1",
    "@types/node": "^18.15.0",
    "typescript": "^4.9.5",
    "vite": "^4.1.4",
    "@vitejs/plugin-react": "^3.1.0",
    "ts-node": "^10.9.1",
    "concurrently": "^7.6.0"
  }
}
