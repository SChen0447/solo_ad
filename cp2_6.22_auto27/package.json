{
  "name": "live-music-manager",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc && vite build"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "express": "4.18.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "typescript": "5.3.3",
    "vite": "5.0.8",
    "@vitejs/plugin-react": "4.2.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.7",
    "@types/express": "^4.17.21",
    "tsx": "^4.6.2",
    "concurrently": "^8.2.2"
  }
}
