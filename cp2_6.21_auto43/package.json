{
  "name": "cafe-inventory-manager",
  "version": "1.0.0",
  "description": "Inventory management and supplier price comparison for independent cafes and bakeries",
  "main": "src/server/server.ts",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "ts-node src/server/server.ts",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "express": "4.18.2",
    "typescript": "5.3.3",
    "vite": "5.0.8",
    "@vitejs/plugin-react": "4.2.0",
    "cors": "2.8.5",
    "uuid": "9.0.0",
    "recharts": "2.10.3"
  },
  "devDependencies": {
    "@types/react": "18.2.43",
    "@types/react-dom": "18.2.17",
    "@types/express": "4.17.21",
    "@types/cors": "2.8.17",
    "@types/uuid": "9.0.7",
    "@types/node": "20.10.5",
    "ts-node": "10.9.2",
    "concurrently": "8.2.2"
  }
}
